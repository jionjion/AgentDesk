# DashScope API Key (阿里云百炼平台)
DASHSCOPE_API_KEY=你的阿里云百炼API密钥

# PostgreSQL 数据库配置
DB_HOST=数据库服务器地址
DB_PORT=数据库端口号
DB_NAME=数据库名称
DB_USERNAME=数据库用户名
DB_PASSWORD=数据库密码

# 阿里云 OSS 配置
OSS_ENDPOINT=OSS服务端点地址
OSS_BUCKET=OSS存储桶名称
OSS_ACCESS_KEY_ID=OSS访问密钥ID
OSS_ACCESS_KEY_SECRET=OSS访问密钥密文

# JWT 配置
JWT_SECRET=JWT签名密钥(至少32个字符)