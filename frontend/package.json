    "axios": "^1.7.9",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "electron-builder": "^25.1.8",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vue-tsc": "^2.1.10",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1"
  }
